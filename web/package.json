{
  "name": "kitamanager-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:style": "stylelint \"src/**/*.{css,vue}\"",
    "lint:style:fix": "stylelint \"src/**/*.{css,vue}\" --fix",
    "format": "prettier --write \"src/**/*.{js,ts,vue,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,css,json}\"",
    "type-check": "vue-tsc --noEmit",
    "check-all": "npm run type-check && npm run lint && npm run lint:style && npm run format:check && npm run test:run"
  },
  "dependencies": {
    "@primeuix/themes": "^1.0.0",
    "@vee-validate/zod": "^4.14.0",
    "axios": "^1.7.0",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "pinia": "^2.3.0",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.2.0",
    "vee-validate": "^4.14.0",
    "vue": "^3.5.26",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.30.0",
    "eslint-plugin-vuejs-accessibility": "^2.4.0",
    "happy-dom": "^15.0.0",
    "playwright": "^1.58.0",
    "postcss-html": "^1.7.0",
    "prettier": "^3.4.0",
    "stylelint": "^16.10.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard": "^36.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.1.0"
  }
}
